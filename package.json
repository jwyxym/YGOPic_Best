{
  "name": "ygopic-best",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core-wasm/core_wasm_bg.wasm": "./dist/core-wasm/core_wasm_bg.wasm",
    "./onnx": "./dist/best.onnx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run wasm && npm run build",
    "wasm": "cd core-wasm && wasm-pack build --target web --out-dir pkg && cd ..",
    "build": "vite build"
  },
  "dependencies": {
    "onnxruntime-web": "^1.23.2"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
